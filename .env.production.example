DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ERP_SITE_ADDRESS=localhost
ERP_TIME_ZONE=Asia/Kolkata
ERP_DATE_FORMAT=%d-%m-%Y
ERP_EXPORT_DATE_FORMAT=%Y-%m-%d
ERP_BACKUP_ROOT=/app/backups
ERP_MAINTENANCE_MODE_FILE=/app/maintenance.lock
USE_POSTGRES=1
POSTGRES_DB=erp_phase1
POSTGRES_USER=erp
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
